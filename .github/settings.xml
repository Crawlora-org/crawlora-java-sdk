<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0">
  <!-- Used by the Release workflow to authenticate Maven against the GitHub
       Packages registry with the workflow's built-in GITHUB_TOKEN. -->
  <servers>
    <server>
      <id>github</id>
      <username>${env.GITHUB_ACTOR}</username>
      <password>${env.GITHUB_TOKEN}</password>
    </server>
  </servers>
</settings>
